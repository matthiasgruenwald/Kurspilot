# Nicht-geheime Testkonfiguration fuer eine echte Moodle-Testinstanz mit
# installiertem local_aicoursecreator-Plugin.
#
# Moodle-URL und Token gehoeren nicht in .env. Speichere sie lokal im
# macOS-Schluesselbund:
#   node scripts/moodle-credentials.js set --url <moodle-url> --token <token>
#
# Die Integrationstests laden .env nicht automatisch. Setze die Kurs-ID als
# Prozess-Umgebungsvariable, z.B.:
#   MOODLE_TEST_COURSEID=2 npm test

MOODLE_TEST_COURSEID=2
