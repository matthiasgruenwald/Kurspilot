# Zugangsdaten für eine echte Moodle-Testinstanz mit installiertem
# local_aicoursecreator-Plugin. Wird von test/integration/*.test.js genutzt.
#
# Kopieren nach .env (von .gitignore ignoriert) und Werte eintragen.
# Fehlt eine der Variablen, werden die Integrationstests übersprungen.

MOODLE_URL=https://deine-moodle-test-instanz/moodle
MOODLE_TOKEN=dein-api-token
MOODLE_TEST_COURSEID=2
